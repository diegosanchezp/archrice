# vim: filetype=sh
alias todo='nvim $TODO'

v(){
  alacritty msg config "window.title='nvim'"
  if [ $# -eq 0 ]; then
    # uses VimEnter autocmd which makes the telescope command trigger when neovim has fully initialized
    # avoiding weird cursor positions.

    # If current working directory is ~/repos/ or is child of ~/repos
    if [ "$PWD" = "$HOME/repos" ] || [[ "$PWD" == "$HOME/repos/"* ]]; then
      # List recently opened files of the current working directory 
      nvim -c "autocmd VimEnter * ++once lua require('telescope.builtin').oldfiles({cwd = vim.fn.getcwd()})"
    else
      # Search files with Telescope
      nvim -c "autocmd VimEnter * ++once lua require('telescope.builtin').find_files({ cwd = '.' })"
    fi
  else
    nvim "$@"
  fi
}

alias lz=lazygit
# Override ls default output
alias ls='ls --human-readable --indicator-style=slash --group-directories-first'
alias lst='ls -lt'
alias pd=pushd
alias yt-mp3='yt-dlp --config-location ~/.config/youtube-dl/yt-mp3.conf'
alias youtube-dl='yt-dlp --config-location ~/.config/youtube-dl/yt-dl.conf'
alias luamake=/home/diego/.cache/nvim/nlua/sumneko_lua/lua-language-server/3rd/luamake/luamake
alias androidscreen='scrcpy -d --keyboard=uhid --mouse=uhid'

# open a document, like pdf, .xsl
openfile(){
  setsid -f $OPENER "$1"
}

# Search and open documents in a new window
opendoc(){
  folder="${1:=$HOME/Documents}"
  cd "$folder"
  files=$(fzf --multi)

  if [ -n "$files" ]; then
    while IFS= read -r file; do
      setsid -f $OPENER "$file"
    done <<< "$files"
  fi

  # Return back
  cd -
}

load_env(){
  set -a
  source ${1:-.env}
}

# Copy current working directorie (pwd) to clipboard
cpwd(){
  pwd | xclip -sel clip
}

# Copy last command to clipboard
# Not working currently
lastcpy(){
  echo !! | xclip -sel clip
}

help(){
 "$@" --help | nvim -R -c "set foldmethod=manual" -c "set ft=help" -
}

# for commands like poetry list
page(){
  "$@" | nvim -R -c "set foldmethod=manual" -c "set ft=help"
}

# changes alacritty window title
change_title(){
  alacritty msg config "window.title='${1}'"
}
